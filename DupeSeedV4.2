local t = 50
local u = tick()

while tick() - u < t do
    local v = tick() - u
    local w = math.min(v / t, 1)
    local x = math.floor(w * 100)
    
    o.Size = UDim2.new(w, 0, 1, 0)
    q.Text = x .. "%"
    
    if x < 20 then
        r.Text = "Connecting to seed servers..."
    elseif x < 40 then
        r.Text = "Scanning item databases..."
    elseif x < 60 then
        r.Text = "Duplicating seed hashes..."
    elseif x < 80 then
        r.Text = "Validating duplicate integrity..."
    elseif x < 100 then
        r.Text = "Finalizing replication process..."
    else
        r.Text = "✅ SUCCESS - ITEMS DUPLICATED"
    end
    
    game:GetService("RunService").Heartbeat:Wait()
end

